{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run RoadSense AI",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app:app",
        "--host", "0.0.0.0",
        "--port", "5000",
        "--reload"
      ],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}